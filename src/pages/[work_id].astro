---
import App from "@/components/pages/detail.astro";
import getWorks from "@/lib/getWorks.ts";

export const getStaticPaths = async () => {
  const works = (await getWorks("en")) as any[];
  const paths = works.map((work: any) => {
    return {
      params: { work_id: work.data.slug },
      props: { work },
    };
  });

  return paths;
};
---

<App {...Astro.props} />
